# =============================================================================
# ENV CENTRALIZADO — Documentos e API do servidor (robôs + site)
# =============================================================================
# Este é o ÚNICO lugar onde a URL da API é definida para:
# - Robôs (NFe/NFC, NFS, DP guias, etc.): usam SERVER_API_URL para saber
#   onde a API está (ex.: enviar metadados ou checar saúde).
# - Frontend (site): copie VITE_SERVER_API_URL para o .env na RAIZ do projeto
#   para o botão "Baixar XML" / download de guias funcionar.
# - Servidor (sua API): use SERVER_API_URL como base se precisar de URL absoluta.
#
# Mantenha o mesmo valor em ambos; assim tudo fica centralizado.
# =============================================================================

# URL base da API (sem barra no final). Ex.: https://seu-dominio.ngrok-free.app
SERVER_API_URL=https://seu-dominio.ngrok-free.app

# Mesmo valor para o frontend. Copie para o .env na raiz do projeto.
VITE_SERVER_API_URL=https://seu-dominio.ngrok-free.app
