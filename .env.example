# Supabase (obrigatório para o app conectar ao backend)
# Copie para .env e preencha com os valores do seu projeto em https://supabase.com/dashboard
# Nunca commite o arquivo .env (ele está no .gitignore).

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: use VITE_SUPABASE_PUBLISHABLE_KEY se preferir (o client aceita os dois nomes)
# Login admin/admin123: crie um usuário no Auth (senha admin123) e defina o secret:
# supabase secrets set ADMIN_EMAIL=automacao@fleury.cnt.br

# API do servidor (robôs + download de XMLs/guias): use o valor de docs/env.example
# Copie VITE_SERVER_API_URL de docs/env.example para manter tudo centralizado.
# VITE_SERVER_API_URL=
