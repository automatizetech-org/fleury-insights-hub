# Supabase (obrigatório para o app conectar ao backend)
# Copie para .env e preencha com os valores do seu projeto em https://supabase.com/dashboard
# Nunca commite o arquivo .env (ele está no .gitignore).

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Login admin: crie um usuário no Auth e defina o secret:
# supabase secrets set ADMIN_EMAIL=automacao@fleury.cnt.br

# API do servidor (robôs + download de XMLs/guias) e WhatsApp: valores centralizados em docs/env.example
# Exemplo com ngrok (URL pública):
SERVER_API_URL=https://plagiaristic-elinore-ungloomily.ngrok-free.dev
WHATSAPP_API=https://plagiaristic-elinore-ungloomily.ngrok-free.dev
