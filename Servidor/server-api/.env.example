# =============================================================================
# API de arquivos — Variáveis para rodar na VM
# =============================================================================
# Copie este arquivo para .env na pasta server-api. Só a anon key é necessária.
#
# CONVENÇÃO IMPORTANTE — Pastas na VM = nomes do dashboard:
#   As pastas dentro de EMPRESAS na VM devem ter o MESMO NOME da empresa
#   cadastrada no dashboard (tabela companies.name).
#   Exemplo: empresa "Grupo Fleury" no dashboard → pasta "Grupo Fleury" na VM.
#
# Estrutura esperada no disco (Windows):
#   BASE_PATH\
#   └── EMPRESAS\
#       └── Grupo Fleury\          ← nome igual ao do dashboard
#           └── NFS\
#               ├── arquivo.xml
#               └── arquivo.pdf
# =============================================================================

# Pasta raiz dos documentos na VM (onde está EMPRESAS\)
BASE_PATH=C:\Users\ROBO\Documents

# Porta da API (ngrok aponta para esta porta)
PORT=3001

# Backend WhatsApp — o server-api repassa para ele as rotas que não são de arquivos.
# Na VM: suba o backend do WhatsApp nesta porta (ex.: 3010); o server-api fica na 3001.
WHATSAPP_BACKEND_URL=http://localhost:3010

# Supabase — mesmo projeto do frontend.
SUPABASE_URL=https://ymrzpunyxhroawfwfaod.supabase.co
